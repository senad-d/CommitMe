{
  "name": "@senad-d/commitme",
  "version": "0.1.0",
  "type": "module",
  "description": "Pi extension that gathers git diff and project context to draft or create clear Conventional Commit messages.",
  "license": "MIT",
  "author": "Senad Dizdarević <112484166+senad-d@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/senad-d/commitme.git"
  },
  "bugs": {
    "url": "https://github.com/senad-d/commitme/issues"
  },
  "homepage": "https://github.com/senad-d/commitme#readme",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "commit-message",
    "conventional-commits",
    "git",
    "commit",
    "commitme",
    "typescript",
    "coding-agent"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "docs/**/*.md",
    "src/**/*.ts",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "pi --no-extensions -e .",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.test.mjs",
    "check": "node --check scripts/check-package-contents.mjs",
    "format:check": "node scripts/check-format.mjs",
    "lint": "npm run typecheck && npm run check",
    "pack:dry-run": "npm pack --dry-run --json",
    "check:pack": "node scripts/check-package-contents.mjs",
    "validate": "npm run lint && npm run format:check && npm run test && npm run check:pack"
  },
  "pi": {
    "extensions": [
      "./src/extension.ts"
    ],
    "image": "https://raw.githubusercontent.com/senad-d/commitme/main/img/commitme.png"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.79.8",
    "@earendil-works/pi-coding-agent": "^0.79.8",
    "@types/node": "^25.9.3",
    "typebox": "^1.2.18",
    "typescript": "^6.0.3"
  }
}
